<Window x:Class="klauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KLAUNCHER GTA V" 
        Height="550" Width="820"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        BorderThickness="0"
        Icon="koala_logo.png">

    <Window.Resources>
        <!-- Window title bar button styles -->
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#a5a1c0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2f2a52"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#a5a1c0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#e81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar Button Styles -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="55"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Specific Sidebar Button States -->
        <!-- Instalar (Purple) -->
        <Style x:Key="InstallButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="#6f42c1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#8250df"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#5a32a3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Discord (Dark Grey-Purple) -->
        <Style x:Key="DiscordButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="#272242"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#352f59"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1d1a33"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Jugar (Coral Pink/Red) -->
        <Style x:Key="PlayButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="#f04764"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#f25f78"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#d63450"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- News Navigation Button Style -->
        <Style x:Key="PagerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#272242" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#6f42c1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1d1a33" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Container Border with glow/shadow -->
    <Border Background="#110f22" BorderBrush="#352f55" BorderThickness="1.5" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Custom Title Bar -->
                <RowDefinition Height="Auto" /> <!-- Logo/Header Section -->
                <RowDefinition Height="*" />    <!-- Content Area (Split Left/Right) -->
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0" Background="#0c0b16" Height="30" MouseDown="TitleBar_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Title and Icon -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <Path Data="M19,3H5C3.9,3,3,3.9,3,5v14c0,1.1,0.9,2,2,2h14c1.1,0,2-0.9,2-2V5C21,3.9,22.1,3,19,3z M11,10.5h-1V12H8.5v-1.5h-1V9h1V7.5H10V9h1V10.5z M14,8.5c-0.55,0-1-0.45-1-1s0.45-1,1-1s1,0.45,1,1S14.55,8.5,14,8.5z M16.5,11c-0.55,0-1-0.45-1-1s0.45-1,1-1s1,0.45,1,1S17.05,11,16.5,11z"
                          Fill="#6f42c1" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="KLAUNCHER GTA V" Foreground="#a5a1c0" FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Windows control buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="—" Style="{StaticResource TitleBarButtonStyle}" Click="Minimize_Click" />
                    <Button Content="✕" Style="{StaticResource CloseButtonStyle}" Click="Close_Click" />
                </StackPanel>
            </Grid>

            <!-- Logo Section -->
            <Grid Grid.Row="1" Margin="0,20,0,0">
                <StackPanel HorizontalAlignment="Center">
                    <!-- Koala Logo -->
                    <Image Source="koala_logo.png" Width="64" Height="64" Margin="0,0,0,8" HorizontalAlignment="Center" SnapsToDevicePixels="True">
                        <Image.Effect>
                            <DropShadowEffect Color="#6f42c1" BlurRadius="12" ShadowDepth="0" Opacity="0.6" />
                        </Image.Effect>
                    </Image>

                    <!-- KLAUNCHER Label -->
                    <TextBlock Text="K L A U N C H E R" 
                               Foreground="#a5a1c0" 
                               FontWeight="Bold" 
                               FontSize="10" 
                               HorizontalAlignment="Center"
                               FontFamily="Segoe UI"/>
                    
                    <!-- GTA V Styled Logo Text -->
                    <TextBlock Text="GTA V" 
                               Foreground="#f04764" 
                               FontWeight="Black" 
                               FontSize="36" 
                               HorizontalAlignment="Center"
                               FontFamily="Trebuchet MS">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="2" Direction="315" />
                        </TextBlock.Effect>
                    </TextBlock>

                    <!-- Download Status Indicator (visible when download is active) -->
                    <Border x:Name="DownloadStatusBar" 
                            Background="#1a1833" 
                            BorderBrush="#352f55" 
                            BorderThickness="1" 
                            CornerRadius="6" 
                            Padding="12,6" 
                            Margin="0,10,0,0"
                            HorizontalAlignment="Center"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Pulsing status dot -->
                            <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#00bcd4" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#00bcd4" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                                </Ellipse.Effect>
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Ellipse.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.4" To="1.0" Duration="0:0:0.8"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <TextBlock x:Name="StatusText" 
                                       Text="Descargando..." 
                                       Foreground="#00bcd4" 
                                       FontWeight="SemiBold" 
                                       FontSize="12" 
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Horizontal Divider -->
                    <Border BorderBrush="#4c3b7a" BorderThickness="0,0,0,1" Width="760" Margin="0,15,0,0" />
                </StackPanel>
            </Grid>

            <!-- Workspace Section -->
            <Grid Grid.Row="2" Margin="30,20,30,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" /> <!-- Sidebar Navigation -->
                    <ColumnDefinition Width="*" />   <!-- Dynamic View / News Panel -->
                </Grid.ColumnDefinitions>

                <!-- Sidebar Buttons Stack -->
                <StackPanel Grid.Column="0" VerticalAlignment="Top" Margin="0,10,25,0">
                    <!-- Button INSTALAR -->
                    <Button Style="{StaticResource InstallButtonStyle}" Click="Instalar_Click">
                        <Grid Width="200">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <!-- Gear SVG Icon -->
                            <Path Grid.Column="0" Data="M19.43,12.98c0.04-0.32,0.07-0.64,0.07-0.98s-0.03-0.66-0.07-0.98l2.11-1.65c0.19-0.15,0.24-0.42,0.12-0.64l-2-3.46 c-0.12-0.22-0.39-0.3-0.61-0.22l-2.49,1c-0.52-0.4-1.08-0.73-1.69-0.98l-0.38-2.65C14.46,2.18,14.25,2,14,2h-4 C9.75,2,9.54,2.18,9.51,2.4l-0.38,2.65c-0.61,0.25-1.17,0.59-1.69,0.98l-2.49-1c-0.23-0.09-0.49,0-0.61,0.22l-2,3.46 c-0.13,0.22-0.07,0.49,0.12,0.64l2.11,1.65c-0.04,0.32-0.07,0.65-0.07,0.98s0.03,0.66,0.07,0.98l-2.11,1.65 c-0.19,0.15-0.24,0.42-0.12,0.64l2,3.46c0.12,0.22,0.39,0.3,0.61,0.22l2.49-1c0.52,0.4,1.08,0.73,1.69,0.98l0.38,2.65 C9.54,21.82,9.75,22,10,22h4c0.25,0,0.46-0.18,0.49-0.4l0.38-2.65c0.61-0.25,1.17-0.59,1.69-0.98l2.49,1 c0.23,0.09,0.49,0,0.61-0.22l2-3.46c0.12-0.22,0.07-0.49-0.12-0.64L19.43,12.98z M12,15.5c-1.93,0-3.5-1.57-3.5-3.5 s1.57-3.5,3.5-3.5s3.5,1.57,3.5,3.5S13.93,15.5,12,15.5z" 
                                  Fill="White" Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="INSTALL" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </Grid>
                    </Button>

                    <!-- Button DISCORD -->
                    <Button Style="{StaticResource DiscordButtonStyle}" Click="Discord_Click">
                        <Grid Width="200">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <!-- Discord Logo / Chat SVG Path -->
                            <Path Grid.Column="0" Data="M20,2H4C2.9,2,2,2.9,2,4v18l4-4h14c1.1,0,2-0.9,2-2V4C22,2.9,21.1,2,20,2z M17,11h-4v4h-2v-4H7V9h4V5h2v4h4V11z" 
                                  Fill="White" Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="DISCORD" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </Grid>
                    </Button>

                    <!-- Button JUGAR -->
                    <Button Style="{StaticResource PlayButtonStyle}" Click="Jugar_Click">
                        <Grid Width="200">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <!-- Rocket SVG Path -->
                            <Path Grid.Column="0" Data="M12,2c0,0-7.07,5.5-7.07,12.07c0,2.15,1.25,4.03,3.06,4.93L7,22h2l1-2h4l1,2h2l-1.01-3c1.81-.9,3.06-2.78,3.06-4.93 C19.07,7.5,12,2,12,2zm0,10.5c-1.38,0-2.5-1.12-2.5-2.5s1.12-2.5,2.5-2.5s2.5,1.12,2.5,2.5s-1.12,2.5-2.5,2.5z" 
                                  Fill="White" Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="PLAY" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </Grid>
                    </Button>
                </StackPanel>

                <!-- Dynamic Content Area -->
                <Grid Grid.Column="1">
                    <!-- Default View: News Panel -->
                    <Grid x:Name="PanelNews" Visibility="Visible" Margin="10,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- News Header -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                            <!-- News Icon -->
                            <Path Data="M19,3h-4.18C14.4,1.84,13.3,1,12,1S9.6,1.84,9.18,3H5C3.9,3,3,3.9,3,5v14c0,1.1,0.9,2,2,2h14c1.1,0,2-0.9,2-2V5 C21,3.9,20.1,3,19,3z M12,3c0.55,0,1,0.45,1,1s-0.45,1-1,1s-1-0.45-1-1S11.45,3,12,3z M12,7c0.55,0,1,0.45,1,1v4c0,0.55-0.45,1-1,1 s-1-0.45-1-1V8C11,7.45,11.45,7,12,7z M12,15c0.55,0,1,0.45,1,1v1c0,0.55-0.45,1-1,1s-1-0.45-1-1v-1C11,15.45,11.45,15,12,15z" 
                                  Fill="#6f42c1" Width="22" Height="22" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="LATEST NEWS" 
                                       Foreground="#8250df" 
                                       FontWeight="Bold" 
                                       FontSize="16" 
                                       VerticalAlignment="Center" 
                                       FontFamily="Segoe UI"/>
                        </StackPanel>

                        <!-- News Card Container -->
                        <Border Grid.Row="1" Background="#141223" BorderBrush="#25213b" BorderThickness="1.5" CornerRadius="8" Padding="25">
                            <Grid>
                                <!-- Content text stack -->
                                <StackPanel VerticalAlignment="Center" Margin="0,0,0,30">
                                    <!-- Slide 1: General Info -->
                                    <StackPanel x:Name="NewsSlide1" Visibility="Visible">
                                        <TextBlock Text="NEW CUSTOM LAUNCHER" 
                                                   Foreground="White" 
                                                   FontWeight="Bold" 
                                                   FontSize="18" 
                                                   Margin="0,0,0,20" 
                                                   FontFamily="Segoe UI"/>
                                        <TextBlock Text="OPTIMIZED FOR MAXIMUM PERFORMANCE" Foreground="#a5a1c0" FontSize="13" Margin="0,0,0,10" FontFamily="Segoe UI"/>
                                        <TextBlock Text="EASY TWO-CLICK INSTALLATION" Foreground="#a5a1c0" FontSize="13" Margin="0,0,0,10" FontFamily="Segoe UI"/>
                                        <TextBlock Text="DIRECT SERVER CONNECTION" Foreground="#a5a1c0" FontSize="13" Margin="0,0,0,10" FontFamily="Segoe UI"/>
                                    </StackPanel>

                                    <!-- Slide 2: Launcher Features -->
                                    <StackPanel x:Name="NewsSlide2" Visibility="Collapsed">
                                        <TextBlock Text="KLAUNCHER FEATURES" 
                                                   Foreground="White" 
                                                   FontWeight="Bold" 
                                                   FontSize="18" 
                                                   Margin="0,0,0,20" 
                                                   FontFamily="Segoe UI"/>
                                        <TextBlock Text="AUTOMATIC FILE UPDATES" Foreground="#a5a1c0" FontSize="13" Margin="0,0,0,10" FontFamily="Segoe UI"/>
                                        <TextBlock Text="BUILT-IN FAST EXTRACTION" Foreground="#a5a1c0" FontSize="13" Margin="0,0,0,10" FontFamily="Segoe UI"/>
                                        <TextBlock Text="PAUSE &amp; RESUME DOWNLOADS" Foreground="#a5a1c0" FontSize="13" Margin="0,0,0,10" FontFamily="Segoe UI"/>
                                    </StackPanel>

                                    <!-- Slide 3: VMP Update -->
                                    <StackPanel x:Name="NewsSlide3" Visibility="Collapsed">
                                        <TextBlock Text="VMP UPDATE" 
                                                   Foreground="White" 
                                                   FontWeight="Bold" 
                                                   FontSize="18" 
                                                   Margin="0,0,0,20" 
                                                   FontFamily="Segoe UI"/>
                                        <TextBlock Text="NEW EXCLUSIVE VEHICLE SYSTEM" Foreground="#a5a1c0" FontSize="13" Margin="0,0,0,10" FontFamily="Segoe UI"/>
                                        <TextBlock Text="FPS BOOST AND OPTIMIZATION" Foreground="#a5a1c0" FontSize="13" Margin="0,0,0,10" FontFamily="Segoe UI"/>
                                        <TextBlock Text="BUG FIXES AND STABILITY" Foreground="#a5a1c0" FontSize="13" Margin="0,0,0,10" FontFamily="Segoe UI"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Navigation Buttons Pager -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                                    <Button Style="{StaticResource PagerButtonStyle}" Content="◀" Click="PrevNews_Click" Margin="0,0,8,0" />
                                    <Button Style="{StaticResource PagerButtonStyle}" Content="▶" Click="NextNews_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Content Control to Host Dynamic Views (InstallControl / DownloadProgressControl) -->
                    <ContentControl x:Name="ContentArea" Visibility="Collapsed" Margin="10,0,0,0"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
