<UserControl x:Class="klauncher.InstallControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="450">

    <UserControl.Resources>
        <!-- Flat Button Style Purple -->
        <Style x:Key="PurpleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#6f42c1" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="15,10" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#8250df" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5a32a3" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#443b59" />
                                <Setter Property="Foreground" Value="#888" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat Button Style Coral Pink -->
        <Style x:Key="PinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#f04764" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="20,15" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#f25f78" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#d63450" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#5c363f" />
                                <Setter Property="Foreground" Value="#a5a1c0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom TextBox Style -->
        <Style x:Key="FolderTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#17152c" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#4c3b7a" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#8250df" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="25,10,25,25">
            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <!-- Game Controller SVG Icon -->
                <Path Data="M21,6H3C1.9,6,1,6.9,1,8v8c0,1.1,0.9,2,2,2h18c1.1,0,2-0.9,2-2V8C23,6.9,22.1,6,21,6z M6,13H5v2H4v-2H2v-1h2v-2h1v2h1V13z M9,14.5c-0.28,0-0.5-0.22-0.5-0.5s0.22-0.5,0.5-0.5s0.5,0.22,0.5,0.5S9.28,14.5,9,14.5z M9,11.5c-0.28,0-0.5-0.22-0.5-0.5 s0.22-0.5,0.5-0.5s0.5,0.22,0.5,0.5S9.28,11.5,9,11.5z M14,14.5c-0.28,0-0.5-0.22-0.5-0.5s0.22-0.5,0.5-0.5s0.5,0.22,0.5,0.5 S14.28,14.5,14,14.5z M14,11.5c-0.28,0-0.5-0.22-0.5-0.5s0.22-0.5,0.5-0.5s0.5,0.22,0.5,0.5S14.28,11.5,14,11.5z M19,13h-2v2h-1v-2 h-2v-1h2v-2h1v2h2V13z" 
                      Fill="White" Width="26" Height="26" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBlock Text="INSTALADOR GTA V + VMP" 
                           Foreground="White" 
                           FontWeight="Bold" 
                           FontSize="18" 
                           VerticalAlignment="Center" 
                           FontFamily="Segoe UI"/>
            </StackPanel>

            <!-- Line Separator -->
            <Border BorderBrush="#4c3b7a" BorderThickness="0,0,0,1" Margin="0,0,0,15" />

            <!-- Installation Folder -->
            <StackPanel Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <!-- Folder SVG Icon -->
                    <Path Data="M10,4H4C2.9,4,2,4.9,2,6v12c0,1.1,0.9,2,2,2h16c1.1,0,2-0.9,2-2V8c0-1.1-0.9-2-2-2h-8L10,4z" 
                          Fill="#a5a1c0" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="CARPETA DE INSTALACIÓN" 
                               Foreground="#a5a1c0" 
                               FontWeight="Bold" 
                               FontSize="11" 
                               FontFamily="Segoe UI"/>
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <TextBox x:Name="TxtInstallPath" 
                             Grid.Column="0" 
                             Style="{StaticResource FolderTextBoxStyle}" 
                             Text="C:\Games\GTAV_KLAUNCHER" />
                    
                    <Button Grid.Column="1" 
                            Content="Examinar" 
                            Style="{StaticResource PurpleButtonStyle}" 
                            Width="100" 
                            Margin="10,0,0,0" 
                            Click="BrowseFolder_Click" />
                </Grid>
            </StackPanel>

            <!-- Space Required Info -->
            <StackPanel Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Path Data="M19,13H5V11H19V13ZM19,17H5V15H19V17ZM19,9H5V7H19V9ZM21,3H3A2,2,0,0,0,1,5V19a2,2,0,0,0,2,2H21a2,2,0,0,0,2-2V5A2,2,0,0,0,21,3Z" 
                          Fill="#a5a1c0" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Espacio necesario:" 
                               Foreground="White" 
                               FontWeight="SemiBold" 
                               FontSize="13" 
                               FontFamily="Segoe UI"/>
                </StackPanel>

                <TextBlock Text="• DirectX + Visual C++: ~500 MB" Foreground="#a5a1c0" FontSize="12" Margin="10,2,0,2" FontFamily="Segoe UI"/>
                <TextBlock Text="• VMP: ~50 MB" Foreground="#a5a1c0" FontSize="12" Margin="10,2,0,2" FontFamily="Segoe UI"/>
                <TextBlock Text="• GTA V Completo: ~70 GB (140 GB temporal)" Foreground="#f04764" FontWeight="SemiBold" FontSize="12" Margin="10,2,0,2" FontFamily="Segoe UI"/>
            </StackPanel>

            <!-- Download Button -->
            <Button x:Name="BtnDownload" 
                    Style="{StaticResource PinkButtonStyle}" 
                    Margin="0,0,0,15" 
                    Click="Download_Click">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M19.35,10.04C18.67,6.59,15.64,4,12,4 9.11,4 6.6,5.64,5.35,8.04 2.34,8.36 0,10.91 0,14c0,3.31,2.69,6,6,6h13c2.76,0,5-2.24,5-5 0-2.64-2.05-4.78-4.65-4.96zM17,13l-5,5-5-5h3V9h4v4h3z" 
                          Fill="White" Width="20" Height="20" Stretch="Uniform" Margin="0,0,10,0" VerticalAlignment="Center" />
                    <TextBlock Text="DESCARGAR GTA V" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Explanation details -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="Descarga los 29 archivos .rar y los descomprime:" Foreground="#a5a1c0" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                <TextBlock Text="• 29 archivos .rar (part01.rar a part29.rar)" Foreground="#a5a1c0" FontSize="12" Margin="10,0,0,2" FontFamily="Segoe UI"/>
                <TextBlock Text="• Tamaño total: ~70 GB" Foreground="#a5a1c0" FontSize="12" Margin="10,0,0,2" FontFamily="Segoe UI"/>
                <TextBlock Text="• Se descomprimirá automáticamente" Foreground="#a5a1c0" FontSize="12" Margin="10,0,0,2" FontFamily="Segoe UI"/>
                <TextBlock Text="• Tiempo estimado: Varias horas" Foreground="#a5a1c0" FontSize="12" Margin="10,0,0,2" FontFamily="Segoe UI"/>
            </StackPanel>

            <!-- Tip -->
            <TextBlock Text="💡 Recomendado: Instalar requisitos primero" 
                       Foreground="#a5a1c0" 
                       FontStyle="Italic" 
                       FontSize="12" 
                       Margin="0,0,0,10" 
                       FontFamily="Segoe UI"/>

            <!-- Install Requirements Button -->
            <Button x:Name="BtnRequirements" 
                    Content="⚙️ INSTALAR REQUISITOS" 
                    Style="{StaticResource PurpleButtonStyle}" 
                    Height="40" 
                    Click="Requirements_Click" />

            <!-- Requirements Details (Initially Collapsed) -->
            <StackPanel x:Name="PanelRequirements" Visibility="Collapsed" Margin="0,15,0,0">
                <TextBlock Text="Instala DirectX y Visual C++ Redistributable:" 
                           Foreground="#a5a1c0" 
                           FontSize="12" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,10"
                           FontFamily="Segoe UI"/>

                <!-- Item 1: DirectX -->
                <Grid Margin="5,0,0,8" Cursor="Hand" MouseLeftButtonDown="DxInstall_Click">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="1. 🎮" Foreground="White" FontSize="12" Margin="0,0,10,0" FontFamily="Segoe UI"/>
                    <TextBlock Grid.Column="1" Text="Microsoft DirectX 11 Runtime (Descargar e Instalar)" 
                               Foreground="LightBlue" TextDecorations="Underline" FontSize="12" FontFamily="Segoe UI"/>
                </Grid>

                <!-- Item 2: VC++ -->
                <Grid Margin="5,0,0,8" Cursor="Hand" MouseLeftButtonDown="VcInstall_Click">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="2. ⚙️" Foreground="White" FontSize="12" Margin="0,0,10,0" FontFamily="Segoe UI"/>
                    <TextBlock Grid.Column="1" Text="Visual C++ Redistributable 2015-2022 (Descargar e Instalar)" 
                               Foreground="LightBlue" TextDecorations="Underline" FontSize="12" FontFamily="Segoe UI"/>
                </Grid>

                <!-- Item 3 -->
                <Grid Margin="5,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="3. ☑️" Foreground="White" FontSize="12" Margin="0,0,10,0" FontFamily="Segoe UI"/>
                    <TextBlock Grid.Column="1" Text="Ambos necesarios para jugar" Foreground="#a5a1c0" FontSize="12" FontFamily="Segoe UI"/>
                </Grid>

                <!-- Status msg green -->
                <TextBlock Text="Solo necesitas instalar esto UNA VEZ" 
                           Foreground="#2ecc71" 
                           FontWeight="SemiBold" 
                           FontSize="12" 
                           Margin="5,10,0,0" 
                           FontFamily="Segoe UI"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
