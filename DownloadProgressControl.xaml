<UserControl x:Class="klauncher.DownloadProgressControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="430" d:DesignWidth="450">

    <UserControl.Resources>

        <!-- Animated gradient brush shared by both bars -->
        <LinearGradientBrush x:Key="ShimmerBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#6f42c1" Offset="0"/>
            <GradientStop Color="#a878ff" Offset="0.45"/>
            <GradientStop Color="#6f42c1" Offset="1"/>
        </LinearGradientBrush>

        <!-- Flat Pause/Resume Button -->
        <Style x:Key="ControlButtonStyle" TargetType="Button">
            <Setter Property="Background"        Value="White"/>
            <Setter Property="Foreground"        Value="Black"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="FontSize"          Value="14"/>
            <Setter Property="Padding"           Value="20,10"/>
            <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#e0e0e0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#b0b0b0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Animated purple progress bar (per-file) -->
        <Style x:Key="OutlinedProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="#cccccc"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Height"          Value="20"/>
            <Setter Property="Foreground"      Value="{StaticResource ShimmerBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot">
                            <Border BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Background="#110f22"
                                    CornerRadius="2"/>
                            <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    HorizontalAlignment="Left"
                                    CornerRadius="1"
                                    Margin="2"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Animated green progress bar (total) -->
        <Style x:Key="GreenProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Background"      Value="#25213b"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot">
                            <Border Background="{TemplateBinding Background}" CornerRadius="2"/>
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    CornerRadius="2">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#1a9e55" Offset="0"/>
                                        <GradientStop Color="#2ecc71" Offset="0.5"/>
                                        <GradientStop Color="#1a9e55" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <StackPanel Margin="30,20,30,30" VerticalAlignment="Center">

        <!-- Title -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Center">
            <!-- Pulsing active downloading/extracting dot -->
            <Grid x:Name="ActiveDotGrid" Margin="0,0,8,0" VerticalAlignment="Center" Visibility="Visible">
                <Ellipse x:Name="PulsingDot" Width="8" Height="8" Fill="#00bcd4">
                    <Ellipse.Effect>
                        <DropShadowEffect x:Name="DotGlow" Color="#00bcd4" BlurRadius="12" ShadowDepth="0" Opacity="0.9"/>
                    </Ellipse.Effect>
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Ellipse.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="1.0" Duration="0:0:0.8"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)" From="4" To="16" Duration="0:0:0.8"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
            </Grid>
            
            <!-- Static paused dot -->
            <Grid x:Name="PausedDotGrid" Margin="0,0,8,0" VerticalAlignment="Center" Visibility="Collapsed">
                <Ellipse Width="8" Height="8" Fill="#f0b429">
                    <Ellipse.Effect>
                        <DropShadowEffect Color="#f0b429" BlurRadius="6" ShadowDepth="0" Opacity="0.6"/>
                    </Ellipse.Effect>
                </Ellipse>
            </Grid>

            <!-- Modern cloud download animated icon -->
            <Grid Width="26" Height="26" Margin="0,0,10,0" VerticalAlignment="Center">
                <!-- Cloud base -->
                <Path Data="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96z"
                      Fill="#6f42c1" Stretch="Uniform"/>
                <!-- Arrow sliding down inside the cloud -->
                <Path x:Name="DownloadArrow" Data="M12 17l-4-4h3V9h2v4h3l-4 4z"
                      Fill="#00bcd4" Stretch="Uniform" RenderTransformOrigin="0.5,0.5">
                    <Path.RenderTransform>
                        <TranslateTransform x:Name="ArrowTranslate"/>
                    </Path.RenderTransform>
                    <Path.Triggers>
                        <EventTrigger RoutedEvent="Path.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="ArrowTranslate"
                                                     Storyboard.TargetProperty="Y"
                                                     From="-4" To="4" Duration="0:0:1.2"/>
                                    <DoubleAnimation Storyboard.TargetName="DownloadArrow"
                                                     Storyboard.TargetProperty="Opacity"
                                                     From="1.0" To="0.0" Duration="0:0:1.2"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Path.Triggers>
                </Path>
            </Grid>

            <TextBlock x:Name="TxtTitle"
                       Text="DESCARGANDO GTA V - VMP Edition"
                       Foreground="#8250df"
                       FontWeight="Bold"
                       FontSize="18"
                       VerticalAlignment="Center"
                       FontFamily="Segoe UI"/>
        </StackPanel>

        <!-- Divider -->
        <Border BorderBrush="#4c3b7a" BorderThickness="0,0,0,1" Margin="0,0,0,20"/>

        <!-- Per-file progress bar label -->
        <TextBlock Text="Progreso del archivo actual"
                   Foreground="#6a6486" FontSize="11" FontFamily="Segoe UI"
                   Margin="0,0,0,4"/>

        <!-- File Progress Bar -->
        <ProgressBar x:Name="FileProgressBar"
                     Style="{StaticResource OutlinedProgressBarStyle}"
                     Value="0" Maximum="100"
                     Margin="0,0,0,6"/>

        <!-- Total progress bar label -->
        <TextBlock Text="Progreso total de descarga"
                   Foreground="#6a6486" FontSize="11" FontFamily="Segoe UI"
                   Margin="0,6,0,4"/>

        <!-- Total Progress Bar -->
        <ProgressBar x:Name="TotalProgressBar"
                     Style="{StaticResource GreenProgressBarStyle}"
                     Value="0" Maximum="100"
                     Margin="0,0,0,16"/>

        <!-- Status / filename -->
        <TextBlock x:Name="TxtFileName"
                   Text="Preparando descarga…"
                   Foreground="#a5a1c0"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   Margin="0,0,0,6"
                   TextTrimming="CharacterEllipsis"
                   FontFamily="Segoe UI"/>

        <!-- Speed and ETA row -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock x:Name="TxtSpeed"
                       Text="0.0 MB/s"
                       Foreground="#00bcd4"
                       FontWeight="SemiBold"
                       FontSize="14"
                       FontFamily="Segoe UI"/>
            <TextBlock Text=" • " Foreground="#55506a" FontSize="14" FontFamily="Segoe UI"/>
            <TextBlock x:Name="TxtEta"
                       Text="Calculando…"
                       Foreground="#f0b429"
                       FontWeight="SemiBold"
                       FontSize="14"
                       FontFamily="Segoe UI"/>
        </StackPanel>

        <!-- Pause / Resume button -->
        <Button x:Name="BtnPause"
                Style="{StaticResource ControlButtonStyle}"
                Width="120"
                Click="Pause_Click"
                HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <Path x:Name="IconPause" Data="M6,19h4V5H6V19z M14,5v14h4V5H14z"
                      Fill="Black" Width="12" Height="12" Stretch="Uniform"
                      Margin="0,0,8,0" VerticalAlignment="Center"/>
                <Path x:Name="IconPlay" Data="M8,5v14l11-7L8,5z"
                      Fill="Black" Width="12" Height="12" Stretch="Uniform"
                      Margin="0,0,8,0" VerticalAlignment="Center" Visibility="Collapsed"/>
                <TextBlock x:Name="TxtPauseButton" Text="Pausar" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>

    </StackPanel>
</UserControl>
