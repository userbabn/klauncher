<Window x:Class="klauncher.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Descargar GTA V" 
        Height="250" Width="440"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        BorderThickness="0"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <!-- Custom Button Style -->
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#25213b" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#4c3b7a" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="20,8" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3d3761" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#6f42c1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1b182d" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#131124" BorderBrush="#352f55" BorderThickness="1.5" CornerRadius="8">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Content Area -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Blue Circular Question Mark Icon -->
                <Grid Grid.Column="0" Width="48" Height="48" VerticalAlignment="Top" Margin="0,5,15,0">
                    <Ellipse Fill="#1a73e8" />
                    <Path Data="M12,2A10,10,0,1,0,22,12,10,10,0,0,0,12,2Zm1,16H11V16h2Zm1.07-7.75l-.9.92C12.45,11.9,12,12.5,12,14H10V13.5a3.5,3.5,0,0,1,1-2.5l1.24-1.25A1.5,1.5,0,0,0,12,7.5a1.5,1.5,0,0,0-1.5,1.5H8.5A3.5,3.5,0,1,1,14.07,10.25Z" 
                          Fill="White" Stretch="Uniform" Width="28" Height="28" Margin="0,-2,0,0"/>
                </Grid>

                <!-- Text content -->
                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                    <TextBlock Text="DESCARGAR GTA V COMPLETO" 
                               Foreground="White" 
                               FontFamily="Segoe UI" 
                               FontWeight="Bold" 
                               FontSize="15" 
                               Margin="0,0,0,10" />

                    <TextBlock Text="Esto descargará 29 archivos .rar:" 
                               Foreground="#a5a1c0" 
                               FontFamily="Segoe UI" 
                               FontSize="12" 
                               Margin="0,0,0,5" />

                    <TextBlock Text="• Tamaño total: ~70 GB" 
                               Foreground="#a5a1c0" 
                               FontFamily="Segoe UI" 
                               FontSize="12" 
                               Margin="10,0,0,2" />

                    <TextBlock Text="• Se descomprimirá automáticamente" 
                               Foreground="#a5a1c0" 
                               FontFamily="Segoe UI" 
                               FontSize="12" 
                               Margin="10,0,0,2" />

                    <TextBlock Text="• Tiempo: Varias horas" 
                               Foreground="#a5a1c0" 
                               FontFamily="Segoe UI" 
                               FontSize="12" 
                               Margin="10,0,0,10" />

                    <TextBlock Text="¿Seguro que quieres continuar?" 
                               Foreground="White" 
                               FontFamily="Segoe UI" 
                               FontWeight="SemiBold" 
                               FontSize="13" 
                               Margin="0,5,0,0" />
                </StackPanel>
            </Grid>

            <!-- Buttons Area -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Sí" Style="{StaticResource DialogButtonStyle}" Width="90" Click="Yes_Click" Margin="0,0,10,0" IsDefault="True"/>
                <Button Content="No" Style="{StaticResource DialogButtonStyle}" Width="90" Click="No_Click" IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
